<?xml version="1.0"?>
<ruleset name="Feed to Blogroll Plugin">
	<description>PHP CodeSniffer ruleset for Feed to Blogroll plugin with enhanced security and accessibility standards</description>

	<!-- Include WordPress Coding Standards -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<!-- Exclude some rules that are too strict for this project -->
	<rule ref="WordPress-Extra">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<!-- Custom rules for this plugin -->
	<rule ref="WordPress-Extra">
		<!-- Allow short array syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
		<!-- Allow alternative control structure syntax -->
		<exclude name="Generic.ControlStructures.InlineControlStructure"/>
	</rule>

	<!-- Security-specific rules -->
	<rule ref="WordPress-Security">
		<!-- Allow wp_verify_nonce for security -->
		<exclude name="WordPress.Security.NonceVerification.Missing"/>
		<!-- Allow wp_verify_nonce for AJAX -->
		<exclude name="WordPress.Security.NonceVerification.Recommended"/>
	</rule>

	<!-- Accessibility and best practices -->
	<rule ref="Generic">
		<!-- Ensure proper escaping -->
		<exclude name="Generic.Functions.CallTimePassByReference"/>
		<!-- Allow modern PHP features -->
		<exclude name="Generic.PHP.DeprecatedFunctions"/>
	</rule>

	<!-- Performance rules -->
	<rule ref="WordPress-Performance">
		<!-- Allow wp_cache_get/set for performance -->
		<exclude name="WordPress.Performance.LowExpensiveFunctions"/>
	</rule>

	<!-- File paths to check -->
	<file>.</file>

	<!-- Exclude vendor and build directories -->
	<exclude-pattern>vendor/</exclude-pattern>
	<exclude-pattern>node_modules/</exclude-pattern>
	<exclude-pattern>assets/</exclude-pattern>
	<exclude-pattern>languages/</exclude-pattern>
	<exclude-pattern>tests/</exclude-pattern>
	<exclude-pattern>build/</exclude-pattern>
	<exclude-pattern>dist/</exclude-pattern>

	<!-- Exclude specific files -->
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>

	<!-- Show progress -->
	<arg value="p"/>
	<arg name="colors"/>

	<!-- Show sniff codes in all reports -->
	<arg value="s"/>

	<!-- Show source codes in all reports -->
	<arg value="n"/>

	<!-- Custom error codes for this plugin -->
	<rule ref="Generic.Files.LineLength">
		<properties>
			<property name="lineLimit" value="120"/>
			<property name="absoluteLineLimit" value="150"/>
		</properties>
	</rule>

	<!-- Enforce proper documentation -->
	<rule ref="WordPress-Docs">
		<!-- Require proper PHPDoc blocks -->
		<exclude name="WordPress.Docs.RequireClassComment"/>
		<!-- Allow short descriptions for simple methods -->
		<exclude name="WordPress.Docs.RequireMethodComment"/>
	</rule>
</ruleset>
