<?xml version="1.0"?>
<ruleset name="Feed Blogroll Plugin">
	<description>PHP CodeSniffer ruleset for Feed Blogroll plugin with enhanced security and accessibility standards</description>

	<!-- Include WordPress Coding Standards (keep to available sets) -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Extra"/>

	<!-- Exclude some rules that are too strict for this project -->
	<rule ref="WordPress-Extra">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<!-- Custom rules for this plugin -->
	<rule ref="WordPress-Extra">
		<!-- Allow alternative control structure syntax -->
		<exclude name="Generic.ControlStructures.InlineControlStructure"/>
	</rule>

	<!-- Security-specific rules: keep defaults, no global exclusions for NonceVerification -->

	<!-- (Removed) Generic rules to avoid conflicts with WP standards and tabs policy -->

	<!-- Performance rules omitted (not available in current PHPCS setup) -->

	<!-- File paths to check -->
	<file>.</file>

	<!-- Exclude vendor and build directories -->
	<exclude-pattern>vendor/</exclude-pattern>
	<exclude-pattern>node_modules/</exclude-pattern>
	<exclude-pattern>assets/</exclude-pattern>
	<exclude-pattern>languages/</exclude-pattern>
	<exclude-pattern>tests/</exclude-pattern>
	<exclude-pattern>build/</exclude-pattern>
	<exclude-pattern>dist/</exclude-pattern>

	<!-- Exclude specific files -->
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>

	<!-- Show progress -->
	<arg value="p"/>
	<arg name="colors"/>

	<!-- Show sniff codes in all reports -->
	<arg value="s"/>

	<!-- Show source codes in all reports -->
	<arg value="n"/>

	<!-- Custom error codes for this plugin -->
	<rule ref="Generic.Files.LineLength">
		<properties>
			<property name="lineLimit" value="120"/>
			<!-- Admin HTML / long translatable strings exceed 150 chars; keep soft limit at 120 -->
			<property name="absoluteLineLimit" value="320"/>
		</properties>
	</rule>

	<!-- Documentation rules omitted (Docs standard not available globally) -->
</ruleset>
